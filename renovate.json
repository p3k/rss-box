{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "security:minimumReleaseAgeNpm",
    "schedule:daily",
    ":automergeMajor",
    ":pinVersions",
    ":semanticCommitsDisabled"
  ],
  "labels": ["dependency"],
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "labels": ["urgent"],
    "automerge": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "git-submodules": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchPackageNames": ["svelte"],
      "allowedVersions": "^4.0.0"
    }
  ]
}
